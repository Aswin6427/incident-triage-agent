# Normalize line endings. Files that run inside Linux containers MUST stay LF
# regardless of the OS they were committed from.
* text=auto

*.sh            text eol=lf
*.template      text eol=lf
Dockerfile*     text eol=lf
*.py            text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf

# Windows-only helper scripts
*.ps1           text eol=crlf

# Binary assets
*.faiss         binary
*.pkl           binary
*.pdf           binary
