# ─────────────────────────────────────────────────────────────
# Azure OpenAI Configuration
# Auth uses an API key. The chat/embedding values are Azure
# *deployment* names (as created in your Azure OpenAI resource),
# not raw model ids.
# ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://2226375-6041-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─────────────────────────────────────────────────────────────
# Backend Configuration
# ─────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─────────────────────────────────────────────────────────────
# Mock External Services (start each in a separate terminal)
# ─────────────────────────────────────────────────────────────
MOCK_JIRA_URL=http://localhost:8001
MOCK_SPLUNK_URL=http://localhost:8002
MOCK_SERVICENOW_URL=http://localhost:8003
MOCK_SLACK_URL=http://localhost:8004

# ─────────────────────────────────────────────────────────────
# RAG / Vector store — Azure Database for PostgreSQL (+ pgvector)
# psycopg (v3) driver URL; Azure Postgres requires sslmode=require.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
PG_COLLECTION_NAME=incident_triage_kb
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# ─────────────────────────────────────────────────────────────
# Agent Behaviour
# ─────────────────────────────────────────────────────────────
MAX_TRIAGE_TIMEOUT_SECONDS=90
LOG_WINDOW_MINUTES=30
MAX_SIMILAR_INCIDENTS=5
