# Rendered by the nginx image's envsubst at container start.
# Only ${BACKEND_HOST} is substituted (it is the sole env var referenced);
# nginx runtime variables like $http_upgrade are left untouched.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 8080;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # SPA — serve static assets, fall back to index.html for client routes
    location / {
        try_files $uri $uri/ /index.html;
    }

    # REST API → backend service
    location ~ ^/(alert|incidents|predictions|post-mortems|health|docs|openapi\.json) {
        proxy_pass               https://${BACKEND_HOST};
        proxy_ssl_server_name    on;
        proxy_http_version       1.1;          # default is HTTP/1.0, which ACA ingress rejects with 426
        proxy_set_header         Connection "";
        proxy_set_header         Host ${BACKEND_HOST};
        proxy_set_header         X-Forwarded-Proto $scheme;
        proxy_set_header         X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # WebSocket → backend Cloud Run service
    location /ws {
        proxy_pass               https://${BACKEND_HOST};
        proxy_ssl_server_name    on;
        proxy_set_header         Host ${BACKEND_HOST};
        proxy_http_version       1.1;
        proxy_set_header         Upgrade $http_upgrade;
        proxy_set_header         Connection $connection_upgrade;
        proxy_read_timeout       3600s;
    }
}
